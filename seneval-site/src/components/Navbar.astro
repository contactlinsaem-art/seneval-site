---

---

<header class="w-full bg-white border-b border-gray-100 sticky top-0 z-50">
  <nav
    class="max-w-6xl mx-auto px-6 py-0 flex items-center justify-between h-20"
  >
    <!-- LOGO -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <img src="/logo.jpg" alt="SEN'EVAL" class="h-14 w-auto" />
    </a>

    <!-- LIENS DESKTOP -->
    <ul
      class="hidden md:flex items-center gap-1 text-sm font-medium text-sen-blue"
    >
      <li>
        <a
          href="/"
          class="px-4 py-2 rounded-full hover:bg-sen-light hover:text-sen-blue transition-colors"
        >
          Accueil
        </a>
      </li>
      <li>
        <a
          href="/evaluation"
          class="px-4 py-2 rounded-full hover:bg-sen-light hover:text-sen-blue transition-colors"
        >
          Évaluation
        </a>
      </li>
      <li>
        <a
          href="/faq"
          class="px-4 py-2 rounded-full hover:bg-sen-light hover:text-sen-blue transition-colors"
        >
          FAQ
        </a>
      </li>
      <li>
        <a
          href="/blog"
          class="px-4 py-2 rounded-full hover:bg-sen-light hover:text-sen-blue transition-colors"
        >
          Blog
        </a>
      </li>
    </ul>

    <!-- CTA DESKTOP -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="/contact"
        class="bg-sen-blue text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-sen-green transition-colors shadow-sm"
      >
        Demander un devis
      </a>
    </div>

    <!-- HAMBURGER MOBILE -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Ouvrir le menu"
    >
      <span class="block w-6 h-0.5 bg-sen-blue transition-all menu-bar"></span>
      <span class="block w-6 h-0.5 bg-sen-blue transition-all menu-bar"></span>
      <span class="block w-6 h-0.5 bg-sen-blue transition-all menu-bar"></span>
    </button>
  </nav>

  <!-- MENU MOBILE -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-100 px-6 pb-6"
  >
    <ul class="flex flex-col gap-1 pt-4 text-sm font-medium text-sen-blue">
      <li>
        <a
          href="/"
          class="block px-4 py-3 rounded-xl hover:bg-sen-light transition-colors"
          >Accueil</a
        >
      </li>
      <li>
        <a
          href="/evaluation"
          class="block px-4 py-3 rounded-xl hover:bg-sen-light transition-colors"
          >Évaluation</a
        >
      </li>
      <li>
        <a
          href="/faq"
          class="block px-4 py-3 rounded-xl hover:bg-sen-light transition-colors"
          >FAQ</a
        >
      </li>
      <li>
        <a
          href="/blog"
          class="block px-4 py-3 rounded-xl hover:bg-sen-light transition-colors"
          >Blog</a
        >
      </li>
      <li class="pt-2">
        <a
          href="/contact"
          class="block text-center bg-sen-blue text-white px-6 py-3 rounded-full font-semibold hover:bg-sen-green transition-colors"
        >
          Demander un devis
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
