---

---

<footer class="bg-sen-blue text-white">
  <div
    class="max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10"
  >
    <!-- COLONNE 1 : Logo + description -->
    <div class="sm:col-span-2 md:col-span-1">
      <img src="/logo_VF.png" alt="SEN'EVAL" class="h-28 w-auto mb-5" />
      <p class="text-sm text-blue-200 leading-relaxed mb-5">
        Cabinet spécialisé dans l'évaluation des établissements et services
        sociaux et médico-sociaux.
      </p>
      <div class="flex gap-2">
        <span
          class="bg-white/15 text-white text-xs font-semibold px-3 py-1.5 rounded-full"
          >Agréé HAS</span
        >
        <span
          class="bg-sen-green text-white text-xs font-semibold px-3 py-1.5 rounded-full"
          >COFRAC</span
        >
      </div>
    </div>

    <!-- COLONNE 2 : Navigation -->
    <div>
      <h3 class="font-bold text-white mb-5 text-sm uppercase tracking-widest">
        Navigation
      </h3>
      <ul class="space-y-3 text-sm text-blue-200">
        <li>
          <a
            href="/"
            class="hover:text-white transition-colors flex items-center gap-2"
            ><span class="text-sen-green">›</span> Accueil</a
          >
        </li>
        <li>
          <a
            href="/evaluation"
            class="hover:text-white transition-colors flex items-center gap-2"
            ><span class="text-sen-green">›</span> Évaluation</a
          >
        </li>
        <li>
          <a
            href="/faq"
            class="hover:text-white transition-colors flex items-center gap-2"
            ><span class="text-sen-green">›</span> FAQ</a
          >
        </li>
        <li>
          <a
            href="/blog"
            class="hover:text-white transition-colors flex items-center gap-2"
            ><span class="text-sen-green">›</span> Blog</a
          >
        </li>
        <li>
          <a
            href="/contact"
            class="hover:text-white transition-colors flex items-center gap-2"
            ><span class="text-sen-green">›</span> Contact</a
          >
        </li>
      </ul>
    </div>

    <!-- COLONNE 3 : Contact -->
    <div>
      <h3 class="font-bold text-white mb-5 text-sm uppercase tracking-widest">
        Contact
      </h3>
      <ul class="space-y-3 text-sm text-blue-200">
        <li class="flex items-center gap-3">
          <svg
            class="w-4 h-4 text-sen-green shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          07.61.28.63.16
        </li>
        <li class="flex items-center gap-3">
          <svg
            class="w-4 h-4 text-sen-green shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          contact@seneval.fr
        </li>
        <li class="flex items-start gap-3">
          <svg
            class="w-4 h-4 text-sen-green shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
            ></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          3 Rue Maya Angelou, 44200 Nantes
        </li>
      </ul>
    </div>

    <!-- COLONNE 4 : CTA + LinkedIn -->
    <div>
      <h3 class="font-bold text-white mb-5 text-sm uppercase tracking-widest">
        Demande de devis
      </h3>
      <p class="text-sm text-blue-200 mb-5 leading-relaxed">
        Votre évaluation sur-mesure, réalisée par des experts agréés HAS et
        COFRAC.
      </p>
      <a
        href="/contact"
        class="inline-block bg-sen-green text-white px-6 py-3 rounded-full text-sm font-semibold hover:opacity-90 transition-opacity mb-6"
      >
        Nous contacter
      </a>
      <div>
        <a
          href="https://www.linkedin.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-blue-200 hover:text-white transition-colors text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          Suivre sur LinkedIn
        </a>
      </div>
    </div>
  </div>

  <!-- BARRE DE COPYRIGHT -->
  <div class="border-t border-white/10">
    <div
      class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-blue-300"
    >
      <p>© 2025 SEN'EVAL — Tous droits réservés</p>
      <div class="flex gap-5">
        <a href="/mentions-legales" class="hover:text-white transition-colors"
          >Mentions légales</a
        >
        <a
          href="/politique-confidentialite"
          class="hover:text-white transition-colors">Confidentialité</a
        >
      </div>
    </div>
  </div>
</footer>
