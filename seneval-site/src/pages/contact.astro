---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">
  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
  <section class="relative bg-sen-blue overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-sen-green"
      >
      </div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6 py-24 md:py-32 text-center">
      <div
        class="inline-flex items-center gap-2 bg-white/15 text-white text-xs font-semibold px-4 py-2 rounded-full mb-8 uppercase tracking-widest"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"
          ><path
            d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
          ></path></svg
        >
        Prise de contact
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Contactez-nous
      </h1>
      <p class="text-lg text-blue-200 max-w-2xl mx-auto">
        Vous souhaitez davantage d'informations ou un devis ? Notre équipe vous
        répond rapidement.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════ CONTENU ═══════════════════════ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
      <!-- FORMULAIRE -->
      <div>
        <p
          class="text-sen-green text-sm font-bold uppercase tracking-widest mb-3"
        >
          Formulaire
        </p>
        <h2 class="text-2xl md:text-3xl font-bold text-sen-blue mb-8">
          Envoyez-nous un message
        </h2>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label
                class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"
              >
                Nom et prénom *
              </label>
              <input
                type="text"
                name="nom"
                required
                placeholder="Jean Dupont"
                class="w-full bg-sen-light border border-transparent rounded-xl px-4 py-3.5 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sen-blue focus:bg-white transition"
              />
            </div>
            <div>
              <label
                class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"
              >
                Email *
              </label>
              <input
                type="email"
                name="email"
                required
                placeholder="jean.dupont@etablissement.fr"
                class="w-full bg-sen-light border border-transparent rounded-xl px-4 py-3.5 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sen-blue focus:bg-white transition"
              />
            </div>
          </div>

          <div>
            <label
              class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"
            >
              Établissement
            </label>
            <input
              type="text"
              name="etablissement"
              placeholder="Nom de votre établissement"
              class="w-full bg-sen-light border border-transparent rounded-xl px-4 py-3.5 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sen-blue focus:bg-white transition"
            />
          </div>

          <div>
            <label
              class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"
            >
              Téléphone
            </label>
            <input
              type="tel"
              name="telephone"
              placeholder="xx.xx.xx.xx.xx"
              class="w-full bg-sen-light border border-transparent rounded-xl px-4 py-3.5 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sen-blue focus:bg-white transition"
            />
          </div>

          <div>
            <label
              class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"
            >
              Votre message *
            </label>
            <textarea
              name="message"
              required
              rows="5"
              placeholder="Décrivez votre besoin, le type d'établissement, le nombre de places..."
              class="w-full bg-sen-light border border-transparent rounded-xl px-4 py-3.5 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sen-blue focus:bg-white transition resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-sen-blue text-white py-4 rounded-full font-semibold hover:bg-sen-green transition-colors shadow-sm text-base"
          >
            Envoyer le message
          </button>
        </form>
      </div>

      <!-- COORDONNÉES -->
      <div>
        <p
          class="text-sen-green text-sm font-bold uppercase tracking-widest mb-3"
        >
          Coordonnées
        </p>
        <h2 class="text-2xl md:text-3xl font-bold text-sen-blue mb-8">
          Nos informations
        </h2>

        <div class="space-y-5">
          <!-- Téléphone -->
          <div class="flex gap-5 items-center bg-sen-light rounded-2xl p-5">
            <div
              class="w-12 h-12 bg-sen-blue rounded-xl flex items-center justify-center shrink-0"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <p
                class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5"
              >
                Téléphone
              </p>
              <p class="font-semibold text-sen-blue">07.61.28.63.16</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-5 items-center bg-sen-light rounded-2xl p-5">
            <div
              class="w-12 h-12 bg-sen-blue rounded-xl flex items-center justify-center shrink-0"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <p
                class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5"
              >
                Email
              </p>
              <p class="font-semibold text-sen-blue">contact@seneval.fr</p>
            </div>
          </div>

          <!-- Adresse -->
          <div class="flex gap-5 items-center bg-sen-light rounded-2xl p-5">
            <div
              class="w-12 h-12 bg-sen-blue rounded-xl flex items-center justify-center shrink-0"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p
                class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5"
              >
                Siège social
              </p>
              <p class="font-semibold text-sen-blue">
                3 Rue Maya Angelou, 44200 Nantes
              </p>
            </div>
          </div>

          <!-- Horaires -->
          <div class="flex gap-5 items-center bg-sen-light rounded-2xl p-5">
            <div
              class="w-12 h-12 bg-sen-blue rounded-xl flex items-center justify-center shrink-0"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <p
                class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5"
              >
                Horaires
              </p>
              <p class="font-semibold text-sen-blue">
                Lundi – Vendredi : 9h – 18h
              </p>
            </div>
          </div>
        </div>

        <!-- ENCART AGRÉMENTS -->
        <div class="mt-8 bg-sen-blue rounded-2xl p-6">
          <p
            class="text-xs font-semibold text-blue-200 uppercase tracking-wide mb-4"
          >
            Nos agréments
          </p>
          <div class="flex gap-3 flex-wrap">
            <span
              class="bg-white text-sen-blue text-sm font-bold px-5 py-2.5 rounded-full"
            >
              ✓ Agréé HAS
            </span>
            <span
              class="bg-sen-green text-white text-sm font-bold px-5 py-2.5 rounded-full"
            >
              ✓ Autorisé COFRAC
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<!-- CONTENU -->
<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
    <!-- FORMULAIRE -->
    <div>
      <h2 class="text-2xl font-bold text-sen-blue mb-8">
        Envoyez-nous un message
      </h2>
      <form name="contact" method="POST" data-netlify="true" class="space-y-6">
        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"
            >Nom et prénom *</label
          >
          <input
            type="text"
            name="nom"
            required
            class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sen-blue transition"
            placeholder="Jean Dupont"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"
            >Email *</label
          >
          <input
            type="email"
            name="email"
            required
            class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sen-blue transition"
            placeholder="jean.dupont@etablissement.fr"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"
            >Établissement</label
          >
          <input
            type="text"
            name="etablissement"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sen-blue transition"
            placeholder="Nom de votre établissement"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"
            >Téléphone</label
          >
          <input
            type="tel"
            name="telephone"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sen-blue transition"
            placeholder="xx.xx.xx.xx.xx"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"
            >Votre message *</label
          >
          <textarea
            name="message"
            required
            rows="5"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sen-blue transition resize-none"
            placeholder="Décrivez votre besoin, le type d'établissement, le nombre de places..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-sen-blue text-white py-4 rounded-full font-semibold hover:bg-sen-green transition-colors"
        >
          Envoyer le message
        </button>
      </form>
    </div>
  </div>
</section>
