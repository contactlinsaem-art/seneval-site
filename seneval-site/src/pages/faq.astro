---
import Layout from "../layouts/Layout.astro";

const faqs = [
  {
    question: "Quand planifier une évaluation ?",
    reponse:
      "Il est recommandé d'anticiper l'évaluation au moins 6 mois avant l'échéance réglementaire. Le décret n° 2022-695 fixe un rythme d'évaluation tous les 5 ans pour l'ensemble des ESSMS.",
  },
  {
    question: "Quel est le prix d'une évaluation ?",
    reponse:
      "Le tarif est établi sur devis en fonction de la taille de l'établissement, du nombre de places, de la nature de l'accompagnement et de la complexité de la structure. Contactez-nous pour obtenir un devis personnalisé.",
  },
  {
    question: "Quel est le nombre d'accompagnés traceurs ?",
    reponse:
      "Le nombre d'accompagnés traceurs dépend de la taille et de la nature de l'établissement. SEN'EVAL s'assure de mobiliser le nombre d'évaluateurs nécessaires pour garantir une évaluation complète et de qualité.",
  },
  {
    question: "En quoi consiste la réunion d'ouverture ?",
    reponse:
      "La réunion d'ouverture marque le démarrage officiel de l'évaluation sur site. Elle réunit l'équipe dirigeante et les évaluateurs pour présenter la méthodologie, le programme de la visite et répondre aux questions de l'établissement.",
  },
  {
    question: "Quelles sont les questions pertinentes avant l'évaluation ?",
    reponse:
      "Avant l'évaluation, il est utile de vérifier la conformité de vos documents institutionnels, de préparer vos équipes à la démarche, de rassembler les indicateurs qualité et de consulter le référentiel HAS pour identifier les points de vigilance.",
  },
  {
    question: "Comment se déroule l'évaluation sur site ?",
    reponse:
      "L'évaluation sur site comprend des visites des locaux, des entretiens individuels et collectifs avec les professionnels, des échanges avec les personnes accompagnées et leurs proches, ainsi que l'observation des pratiques professionnelles.",
  },
  {
    question: "Que se passe-t-il après l'évaluation ?",
    reponse:
      "Après la visite, SEN'EVAL rédige un pré-rapport soumis à l'établissement pour échanges contradictoires. Le rapport définitif est ensuite remis avec les axes d'amélioration identifiés et transmis aux autorités compétentes.",
  },
  {
    question: "SEN'EVAL est-il autorisé par la HAS ?",
    reponse:
      "Oui, SEN'EVAL est autorisé par la Haute Autorité de Santé (HAS), attestant de notre conformité aux exigences réglementaires pour la réalisation des évaluations des ESSMS.",
  },
];
---

<Layout title="FAQ">
  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
  <section class="relative bg-sen-blue overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div
        class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-sen-green"
      >
      </div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6 py-24 md:py-32 text-center">
      <div
        class="inline-flex items-center gap-2 bg-white/15 text-white text-xs font-semibold px-4 py-2 rounded-full mb-8 uppercase tracking-widest"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"
          ><path
            fill-rule="evenodd"
            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z"
            clip-rule="evenodd"></path></svg
        >
        Questions fréquentes
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Tout ce que vous devez savoir
      </h1>
      <p class="text-lg text-blue-200 max-w-2xl mx-auto">
        Retrouvez les réponses aux questions les plus fréquentes sur
        l'évaluation des ESSMS avec SEN'EVAL.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════ FAQ ACCORDÉON ═══════════════════════ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="space-y-3" id="faq-list">
        {
          faqs.map((faq, index) => (
            <div class="border border-gray-200 rounded-2xl overflow-hidden hover:border-sen-blue transition-colors">
              <button
                class="w-full text-left px-7 py-6 flex items-center justify-between gap-6 hover:bg-sen-light transition-colors faq-btn"
                data-index={index}
              >
                <span class="font-semibold text-sen-blue text-base leading-snug">
                  {faq.question}
                </span>
                <span class="shrink-0 w-7 h-7 bg-sen-light rounded-full flex items-center justify-center faq-icon-wrap">
                  <svg
                    class="w-4 h-4 text-sen-green faq-icon transition-transform duration-300"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M12 4v16m8-8H4"
                    />
                  </svg>
                </span>
              </button>
              <div class="faq-answer hidden px-7 pb-6">
                <div class="pt-1 border-t border-gray-100">
                  <p class="text-gray-600 leading-relaxed pt-4">
                    {faq.reponse}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════ CTA ════════════════════════════════ -->
  <section class="bg-sen-light py-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div
        class="w-14 h-14 bg-sen-blue rounded-2xl flex items-center justify-center mx-auto mb-6"
      >
        <svg
          class="w-7 h-7 text-white"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
          ></path>
        </svg>
      </div>
      <h2 class="text-2xl md:text-3xl font-bold text-sen-blue mb-4">
        Vous ne trouvez pas votre réponse ?
      </h2>
      <p class="text-gray-600 mb-8">
        Notre équipe est disponible pour répondre à toutes vos questions.
      </p>
      <a
        href="/contact"
        class="inline-block bg-sen-blue text-white px-10 py-4 rounded-full font-semibold hover:bg-sen-green transition-colors shadow-sm"
      >
        Nous contacter
      </a>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll(".faq-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const answer = btn.nextElementSibling;
      const icon = btn.querySelector(".faq-icon");
      const iconWrap = btn.querySelector(".faq-icon-wrap");
      if (!answer || !icon || !iconWrap) return;
      const isOpen = !answer.classList.contains("hidden");

      // Fermer tous les autres
      document
        .querySelectorAll(".faq-answer")
        .forEach((a) => a.classList.add("hidden"));
      document
        .querySelectorAll(".faq-icon")
        .forEach((i) => i.classList.remove("rotate-45"));
      document
        .querySelectorAll(".faq-icon-wrap")
        .forEach((w) => w.classList.remove("bg-sen-blue"));
      document
        .querySelectorAll(".faq-icon-wrap")
        .forEach((w) => w.classList.add("bg-sen-light"));
      document
        .querySelectorAll(".faq-icon")
        .forEach((i) => i.classList.remove("text-white"));
      document
        .querySelectorAll(".faq-icon")
        .forEach((i) => i.classList.add("text-sen-green"));

      // Ouvrir si était fermé
      if (!isOpen) {
        answer.classList.remove("hidden");
        icon.classList.add("rotate-45");
        iconWrap.classList.remove("bg-sen-light");
        iconWrap.classList.add("bg-sen-blue");
        icon.classList.remove("text-sen-green");
        icon.classList.add("text-white");
      }
    });
  });
</script>
