---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(articles.map((a) => a.data.categorie).filter(Boolean))];
---

<Layout title="Blog">
  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
  <section class="relative bg-sen-blue overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-sen-green"></div>
      <div class="absolute -bottom-16 -left-16 w-72 h-72 rounded-full bg-white"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6 py-24 md:py-32 text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 text-white text-xs font-semibold px-4 py-2 rounded-full mb-8 uppercase tracking-widest">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" />
        </svg>
        Actualités &amp; Ressources
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
        Blog SEN'EVAL
      </h1>
      <p class="text-lg text-blue-200 max-w-2xl mx-auto">
        Retrouvez nos dernières actualités, bonnes pratiques et retours d'expérience sur l'évaluation des ESSMS.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════ FILTRES ════════════════════════════════════════ -->
  {categories.length > 0 && (
    <section class="bg-white border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-6 py-4 flex flex-wrap gap-3 justify-center">
        <a
          href="/blog"
          class="px-4 py-2 rounded-full text-sm font-medium bg-sen-blue text-white transition-colors"
        >
          Tous
        </a>
        {categories.map((cat) => (
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-sen-light text-sen-blue hover:bg-sen-blue hover:text-white transition-colors cursor-default">
            {cat}
          </span>
        ))}
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════ ARTICLES ═══════════════════════════════════════ -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">

      {articles.length === 0 ? (
        <!-- État vide -->
        <div class="text-center py-20">
          <div class="w-20 h-20 bg-sen-light rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-sen-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-sen-blue mb-3">Aucun article pour le moment</h2>
          <p class="text-gray-500">Les premiers articles arrivent bientôt, restez connecté !</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.map((article) => (
            <a
              href={`/blog/${article.id.replace(/\.md$/, "")}`}
              class="group bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col"
            >
              <!-- Image -->
              {article.data.image ? (
                <div class="aspect-[16/10] overflow-hidden bg-sen-light">
                  <img
                    src={article.data.image}
                    alt={article.data.titre}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              ) : (
                <div class="aspect-[16/10] bg-linear-to-br from-sen-blue to-sen-blue/80 flex items-center justify-center">
                  <svg class="w-16 h-16 text-white/30" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
                  </svg>
                </div>
              )}

              <!-- Contenu -->
              <div class="p-6 flex flex-col flex-1">
                <!-- Catégorie + date -->
                <div class="flex items-center gap-3 mb-3">
                  {article.data.categorie && (
                    <span class="text-xs font-semibold text-sen-green bg-green-50 px-3 py-1 rounded-full">
                      {article.data.categorie}
                    </span>
                  )}
                  <span class="text-xs text-gray-400">
                    {new Date(article.data.date).toLocaleDateString("fr-FR", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                    })}
                  </span>
                </div>

                <!-- Titre -->
                <h2 class="text-lg font-bold text-sen-blue group-hover:text-sen-green transition-colors mb-2 line-clamp-2">
                  {article.data.titre}
                </h2>

                <!-- Description -->
                {article.data.description && (
                  <p class="text-sm text-gray-500 mb-4 line-clamp-3 flex-1">
                    {article.data.description}
                  </p>
                )}

                <!-- Auteur + lire -->
                <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-50">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-sen-light flex items-center justify-center">
                      <svg class="w-3.5 h-3.5 text-sen-blue" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <span class="text-xs text-gray-500 font-medium">{article.data.auteur}</span>
                  </div>
                  <span class="text-xs font-semibold text-sen-blue group-hover:text-sen-green transition-colors flex items-center gap-1">
                    Lire
                    <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════ CTA ════════════════════════════════════════ -->
  <section class="bg-sen-light py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-sen-blue mb-4">
        Une question sur l'évaluation ?
      </h2>
      <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
        Contactez-nous pour obtenir un accompagnement personnalisé et un devis adapté à votre structure.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-sen-green text-white px-8 py-4 rounded-full font-semibold hover:opacity-90 transition-opacity shadow-lg"
      >
        Nous contacter
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
